local function GetTarget()
    local Target = nil
    local Dist = Wyvern.Combat.FOV
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild(Wyvern.Combat.TargetPart) then
            if not (Wyvern.Visuals.TeamCheck and v.Team == game.Players.LocalPlayer.Team) then
                local Pos, Visible = workspace.CurrentCamera:WorldToViewportPoint(v.Character[Wyvern.Combat.TargetPart].Position)
                if Visible then
                    local Mag = (Vector2.new(Pos.X, Pos.Y) - game:GetService("UserInputService"):GetMouseLocation()).Magnitude
                    if Mag < Dist then Dist = Mag Target = v.Character[Wyvern.Combat.TargetPart] end
                end
            end
        end
    end
    return Target
end

