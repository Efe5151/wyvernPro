local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

_G.SilentAim = false
_G.AimKey = Enum.KeyCode.E
_G.FOV = 150
_G.ESP = false
_G.WallCheck = true
_G.AutoShoot = false -- Yeni Özellik

local Window = Rayfield:CreateWindow({
   Name = "Wyvern Pro",
   LoadingTitle = "Edit By Roxy",
   LoadingSubtitle = "Auto-Shoot Update",
   ConfigurationSaving = { Enabled = false }
})

local CombatTab = Window:CreateTab("⚔️ Combat")

CombatTab:CreateToggle({
   Name = "Silent Aim Aktif",
   CurrentValue = false,
   Callback = function(v) _G.SilentAim = v end,
})

CombatTab:CreateKeybind({
   Name = "Kilitleme Tuşu",
   CurrentKeybind = "E",
   HoldToInteract = false,
   Callback = function(Key) _G.AimKey = Key end,
})

CombatTab:CreateToggle({
   Name = "Otomatik Ateş (Auto Shoot)",
   CurrentValue = false,
   Callback = function(v) _G.AutoShoot = v end,
})

CombatTab:CreateToggle({
   Name = "Duvar Kontrolü",
   CurrentValue = true,
   Callback = function(v) _G.WallCheck = v end,
})

CombatTab:CreateSlider({
   Name = "FOV",
   Range = {0, 600},
   Increment = 10,
   CurrentValue = 150,
   Callback = function(v) _G.FOV = v end,
})

-- LOGIC MOTORU
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5
FOVCircle.Color = Color3.fromRGB(255, 255, 255)

local function IsVisible(target)
    if not _G.WallCheck then return true end
    local char = game.Players.LocalPlayer.Character
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char, target.Parent}
    local result = workspace:Raycast(workspace.CurrentCamera.CFrame.Position, (target.Position - workspace.CurrentCamera.CFrame.Position).Unit * 500, params)
    return result == nil
end

-- Otomatik Ateş Fonksiyonu (Sol Tık Simülasyonu)
local function Shoot()
    local VirtualInputManager = game:GetService("VirtualInputManager")
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0) -- Sol Tık Bas
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0) -- Sol Tık Bırak
end

game:GetService("RunService").RenderStepped:Connect(function()
    FOVCircle.Visible = _G.SilentAim
    FOVCircle.Radius = _G.FOV
    FOVCircle.Position = game:GetService("UserInputService"):GetMouseLocation()

    if _G.SilentAim and game:GetService("UserInputService"):IsKeyDown(_G.AimKey) then
        local target = nil
        local dist = _G.FOV
        
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local p, vis = workspace.CurrentCamera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                if vis then
                    local m = (Vector2.new(p.X, p.Y) - game:GetService("UserInputService"):GetMouseLocation()).Magnitude
                    if m < dist and IsVisible(v.Character.HumanoidRootPart) then
                        target = v.Character.HumanoidRootPart
                        dist = m
                    end
                end
            end
        end
        
        if target then
            -- Kilitlenme
            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.Position)
            
            -- Otomatik Ateş
            if _G.AutoShoot then
                Shoot()
            end
        end
    end
end)

Rayfield:Notify({Title = "Wyvern Pro", Content = "Auto Shoot ve Tuş Kilidi Düzeldi!", Duration = 5})
