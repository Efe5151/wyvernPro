-- [[ WYVERN PRO - UPDATED SOURCE ]]
-- Edit By Roxy | Wall Check + Dynamic Keybind

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- [[ AYARLAR ]]
_G.SilentAim = false
_G.AimKey = Enum.KeyCode.E -- Başlangıç tuşu
_G.FOV = 150
_G.ESP = false
_G.WallCheck = true -- Duvar arkası kontrolü aktif

local Window = Rayfield:CreateWindow({
   Name = "Wyvern Pro",
   LoadingTitle = "Edit By Roxy",
   LoadingSubtitle = "Xeno Special Edition",
   ConfigurationSaving = { Enabled = false }
})

-- ⚔️ COMBAT SEKİMESİ
local CombatTab = Window:CreateTab("⚔️ Combat")

CombatTab:CreateSection("Silent Aim Ayarları")

CombatTab:CreateToggle({
   Name = "Silent Aim Aktif",
   CurrentValue = false,
   Callback = function(Value) _G.SilentAim = Value end,
})

-- ⌨️ İSTEDİĞİN TUŞA ATAMA BÖLÜMÜ
CombatTab:CreateKeybind({
   Name = "Kilitleme Tuşu (Lock Key)",
   CurrentKeybind = "E",
   HoldToInteract = false,
   Flag = "AimKeybind",
   Callback = function(Keybind)
       _G.AimKey = Keybind
       Rayfield:Notify({Title = "Tuş Atandı", Content = "Yeni tuş: " .. tostring(Keybind), Duration = 2})
   end,
})

CombatTab:CreateToggle({
   Name = "Duvar Kontrolü (Wall Check)",
   CurrentValue = true,
   Callback = function(Value) _G.WallCheck = Value end,
})

CombatTab:CreateSlider({
   Name = "Görüş Alanı (FOV)",
   Range = {0, 600},
   Increment = 10,
   CurrentValue = 150,
   Callback = function(v) _G.FOV = v end,
})

-- 👁️ ESP SEKİMESİ
local ESPTab = Window:CreateTab("👁️ ESP")
ESPTab:CreateToggle({
   Name = "Player ESP",
   CurrentValue = false,
   Callback = function(v) _G.ESP = v end,
})

-- [[ 🚀 SİSTEM MOTORU ]]
local FOVCircle = Drawing.new("Circle")
FOVCircle.Visible = false
FOVCircle.Thickness = 1.5
FOVCircle.Color = Color3.fromRGB(255, 255, 255)

-- Duvar Kontrolü Fonksiyonu
local function IsVisible(targetPart)
    if not _G.WallCheck then return true end
    local char = game.Players.LocalPlayer.Character
    if not char then return false end
    
    local ray = Ray.new(workspace.CurrentCamera.CFrame.Position, (targetPart.Position - workspace.CurrentCamera.CFrame.Position).Unit * 500)
    local hit, pos = workspace:FindPartOnRayWithIgnoreList(ray, {char, targetPart.Parent})
    
    return hit == nil
end

game:GetService("RunService").RenderStepped:Connect(function()
    FOVCircle.Visible = _G.SilentAim
    FOVCircle.Radius = _G.FOV
    FOVCircle.Position = game:GetService("UserInputService"):GetMouseLocation()

    -- ESP Sistemi
    if _G.ESP then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character then
                local h = v.Character:FindFirstChild("RoxyESP") or Instance.new("Highlight", v.Character)
                h.Name = "RoxyESP"
                h.FillColor = Color3.fromRGB(255, 0, 0)
            end
        end
    end

    -- Dinamik Tuş Atamalı Silent Aim
    if _G.SilentAim and game:GetService("UserInputService"):IsKeyDown(_G.AimKey) then
        local target = nil
        local dist = _G.FOV
        
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local p, vis = workspace.CurrentCamera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                
                if vis then
                    local m = (Vector2.new(p.X, p.Y) - game:GetService("UserInputService"):GetMouseLocation()).Magnitude
                    if m < dist then
                        -- Duvar kontrolünü burada yapıyoruz
                        if IsVisible(v.Character.HumanoidRootPart) then
                            target = v.Character.HumanoidRootPart
                            dist = m
                        end
                    end
                end
            end
        end
        
        if target then
            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.Position)
        end
    end
end)

Rayfield:Notify({Title = "Wyvern Pro Güncellendi", Content = "Edit By Roxy - İyi Çekimler!", Duration = 5})
