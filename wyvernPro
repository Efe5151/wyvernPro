-- [[ WYVERN PRO - ROXY MULTI-LANGUAGE V8 ]]
-- Edit By Roxy | Auto Shoot | Keybind | Dual Language

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Global Ayarlar
_G.SilentAim = false
_G.AimKey = Enum.KeyCode.E
_G.FOV = 150
_G.ESP = false
_G.AutoShoot = false

-- Pencere Kurulumu
local Window = Rayfield:CreateWindow({
   Name = "Wyvern Pro | Edit By Roxy",
   LoadingTitle = "Roxy Hub",
   LoadingSubtitle = "Youtube: Pavlov",
   ConfigurationSaving = { Enabled = false }
})

-- [[ 🌍 LANGUAGE / DİL SEKMESİ ]]
local LangTab = Window:CreateTab("🌍 Language / Dil")

local function NotifyLang(title, content)
    Rayfield:Notify({Title = title, Content = content, Duration = 3})
end

-- Menü Elemanlarını Tanımlayalım (Dil değiştikçe güncellenecekler)
local CombatTab = Window:CreateTab("⚔️ Combat")
local VisualsTab = Window:CreateTab("👁️ Visuals")

-- ⚔️ COMBAT ELEMENTS
local SA_Toggle = CombatTab:CreateToggle({
   Name = "Silent Aim (Off)",
   CurrentValue = false,
   Callback = function(v) _G.SilentAim = v end,
})

local Key_Bind = CombatTab:CreateKeybind({
   Name = "Aim Key",
   CurrentKeybind = "E",
   Callback = function(Key) _G.AimKey = Key end,
})

local AS_Toggle = CombatTab:CreateToggle({
   Name = "Auto Shoot (Off)",
   CurrentValue = false,
   Callback = function(v) _G.AutoShoot = v end,
})

local FOV_Slider = CombatTab:CreateSlider({
   Name = "FOV Area",
   Range = {0, 600},
   Increment = 10,
   CurrentValue = 150,
   Callback = function(v) _G.FOV = v end,
})

-- 👁️ VISUAL ELEMENTS
local ESP_Toggle = VisualsTab:CreateToggle({
   Name = "Player ESP",
   CurrentValue = false,
   Callback = function(v) _G.ESP = v end,
})

-- DİL DEĞİŞTİRME BUTONLARI
LangTab:CreateButton({
   Name = "Türkçe Ayarla",
   Callback = function()
       SA_Toggle:Set("Silent Aim Aktif")
       Key_Bind:Set("Kilitleme Tuşu")
       AS_Toggle:Set("Otomatik Ateş")
       FOV_Slider:Set("Görüş Alanı")
       ESP_Toggle:Set("Oyuncu ESP")
       NotifyLang("Başarılı", "Dil Türkçe olarak ayarlandı!")
   end,
})

LangTab:CreateButton({
   Name = "Set English",
   Callback = function()
       SA_Toggle:Set("Silent Aim Active")
       Key_Bind:Set("Aim Key")
       AS_Toggle:Set("Auto Shoot")
       FOV_Slider:Set("FOV Area")
       ESP_Toggle:Set("Player ESP")
       NotifyLang("Success", "Language set to English!")
   end,
})

-- [[ SİSTEM MOTORU ]]
local UIS = game:GetService("UserInputService")
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5
FOVCircle.Color = Color3.fromRGB(255, 255, 255)

game:GetService("RunService").RenderStepped:Connect(function()
    FOVCircle.Visible = _G.SilentAim
    FOVCircle.Radius = _G.FOV
    FOVCircle.Position = UIS:GetMouseLocation()

    -- ESP Sistemi
    if _G.ESP then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character then
                local h = v.Character:FindFirstChild("RoxyESP") or Instance.new("Highlight", v.Character)
                h.Name = "RoxyESP"
                h.FillColor = Color3.fromRGB(255, 0, 0)
            end
        end
    end

    -- SILENT AIM (Sağ Tık Engelleyici Dahil)
    local RightClick = UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    if _G.SilentAim and UIS:IsKeyDown(_G.AimKey) and not RightClick then
        local target = nil
        local dist = _G.FOV
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local p, vis = workspace.CurrentCamera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                if vis then
                    local m = (Vector2.new(p.X, p.Y) - UIS:GetMouseLocation()).Magnitude
                    if m < dist then
                        target = v.Character.HumanoidRootPart
                        dist = m
                    end
                end
            end
        end
        if target then
            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.Position)
            if _G.AutoShoot then
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0,0,0,true,game,0)
                task.wait()
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0,0,0,false,game,0)
            end
        end
    end
end)
