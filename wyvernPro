local function GetTarget()
    local Target = nil
    local MaxDist = Wyvern.Combat.FOV
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
            if not (Wyvern.Visuals.TeamCheck and v.Team == game.Players.LocalPlayer.Team) then
                local ScreenPos, OnScreen = workspace.CurrentCamera:WorldToViewportPoint(v.Character.Head.Position)
                if OnScreen then
                    local Mag = (Vector2.new(ScreenPos.X, ScreenPos.Y) - game:GetService("UserInputService"):GetMouseLocation()).Magnitude
                    if Mag < MaxDist then MaxDist = Mag Target = v.Character.Head end
                end
            end
        end
    end
    return Target
end

