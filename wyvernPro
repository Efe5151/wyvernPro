local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Wyvern Pro", -- Sol üstte görünecek ana başlık
   LoadingTitle = "Edit By Roxy", -- Yükleme ekranında senin imzan
   LoadingSubtitle = "Xeno Special Edition",
   ConfigurationSaving = {
      Enabled = false
   },
   Discord = {
      Enabled = false
   },
   KeySystem = false
})

-- [[ NOT: Rayfield'da sağ tarafa sabit yazı eklemek için Notify veya Label kullanabiliriz ]]
-- [[ Ama en profesyonel duruşu 'Edit By Roxy' bilgisini ana sekmede vererek sağlarız ]]

-- 1. BÖLME: COMBAT
local CombatTab = Window:CreateTab("⚔️ Combat", 4483362458)

CombatTab:CreateSection("Savaş Ayarları | Edit By Roxy") -- Sağ tarafa yakın durması için section başlığına ekledik

CombatTab:CreateToggle({
   Name = "Silent Aim",
   CurrentValue = false,
   Callback = function(Value) _G.SilentAim = Value end,
})

CombatTab:CreateSlider({
   Name = "FOV",
   Range = {0, 500},
   Increment = 10,
   CurrentValue = 100,
   Callback = function(Value) _G.FOV = Value end,
})

-- 2. BÖLME: ESP
local ESPTab = Window:CreateTab("👁️ ESP", 4483362458)

ESPTab:CreateSection("Görsel Ayarlar")

ESPTab:CreateToggle({
   Name = "Player ESP",
   CurrentValue = false,
   Callback = function(Value) _G.ESP_Enabled = Value end,
})

ESPTab:CreateColorPicker({
    Name = "ESP Rengi",
    Color = Color3.fromRGB(255, 0, 0),
    Callback = function(Value) _G.ESP_Color = Value end
})

-- 3. BÖLME: SKINCHANGER
local SkinTab = Window:CreateTab("👕 SkinChanger", 4483362458)

SkinTab:CreateSection("Karakter Özelleştirme")

SkinTab:CreateInput({
   Name = "Shirt ID (Gömlek)",
   PlaceholderText = "ID Gir...",
   Callback = function(Text)
       local char = game.Players.LocalPlayer.Character
       if char then
           local s = char:FindFirstChildOfClass("Shirt") or Instance.new("Shirt", char)
           s.ShirtTemplate = "rbxassetid://" .. Text
       end
   end,
})

SkinTab:CreateInput({
    Name = "Pants ID (Pantolon)",
    PlaceholderText = "ID Gir...",
    Callback = function(Text)
        local char = game.Players.LocalPlayer.Character
        if char then
            local p = char:FindFirstChildOfClass("Pants") or Instance.new("Pants", char)
            p.PantsTemplate = "rbxassetid://" .. Text
        end
    end,
 })

